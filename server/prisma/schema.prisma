generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GroupRole {
  owner
  member
}

enum MembershipStatus {
  active
  inactive
}

enum InvitationStatus {
  pending
  accepted
  declined
}

enum ExpenseCategory {
  food
  transport
  housing
  entertainment
  other
}

enum ExpenseSplitMode {
  equal
  percentage
  exact
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  passwordHash          String
  displayName           String?
  displayNameNormalized String?            @unique
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  sessions              Session[]
  ownedGroups           ExpenseGroup[]     @relation("GroupOwner")
  createdExpenses       Expense[]          @relation("ExpenseCreator")
  expensePayments       ExpensePayer[]     @relation("ExpensePayerUser")
  expenseShares         ExpenseShare[]     @relation("ExpenseShareUser")
  settlementsCreated    Settlement[]       @relation("SettlementCreator")
  settlementsFrom       Settlement[]       @relation("SettlementFromUser")
  settlementsTo         Settlement[]       @relation("SettlementToUser")
  memberships           GroupMembership[]
  invitationsReceived   GroupInvitation[]  @relation("InvitationRecipient")
  invitationsSent       GroupInvitation[]  @relation("InvitationSender")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExpenseGroup {
  id          String            @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  owner       User              @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships GroupMembership[]
  invitations GroupInvitation[]
  expenses    Expense[]
  settlements Settlement[]
}

model Expense {
  id              String         @id @default(cuid())
  groupId         String
  title           String
  category       ExpenseCategory @default(other)
  splitMode      ExpenseSplitMode @default(equal)
  expenseDate     DateTime
  createdByUserId String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  group           ExpenseGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy       User           @relation("ExpenseCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  payers          ExpensePayer[]
  shares          ExpenseShare[]

  @@index([groupId, expenseDate, createdAt])
}

model ExpensePayer {
  id         String   @id @default(cuid())
  expenseId  String
  userId     String
  amountPaid Decimal  @db.Decimal(12, 2)
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user       User     @relation("ExpensePayerUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model ExpenseShare {
  id        String   @id @default(cuid())
  expenseId String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User     @relation("ExpenseShareUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id              String       @id @default(cuid())
  groupId         String
  fromUserId      String
  toUserId        String
  amount          Decimal      @db.Decimal(12, 2)
  paidAt          DateTime
  createdByUserId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  group           ExpenseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser        User         @relation("SettlementFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User         @relation("SettlementToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  createdBy       User         @relation("SettlementCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
}

model GroupMembership {
  id        String           @id @default(cuid())
  groupId   String
  userId    String
  role      GroupRole        @default(member)
  status    MembershipStatus @default(active)
  leftAt    DateTime?
  createdAt DateTime         @default(now())
  group     ExpenseGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupInvitation {
  id              String           @id @default(cuid())
  groupId         String
  invitedUserId   String
  invitedByUserId String
  status          InvitationStatus @default(pending)
  createdAt       DateTime         @default(now())
  respondedAt     DateTime?
  group           ExpenseGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedUser     User             @relation("InvitationRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy       User             @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([groupId, invitedUserId, status])
}
